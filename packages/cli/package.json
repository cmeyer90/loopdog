{
  "name": "@loopdog/cli",
  "version": "0.4.0",
  "description": "Loopdog — autonomous-SDLC loops for any GitHub repository, driven by your existing Claude Code and Codex subscriptions.",
  "license": "Apache-2.0",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@octokit/auth-oauth-device": "^8.0.0",
    "@octokit/rest": "^21.1.1",
    "commander": "^13.1.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.0"
  },
  "bin": {
    "loopdog": "dist/main.js",
    "ldg": "dist/main.js"
  },
  "devDependencies": {
    "@loopdog/core": "0.4.0",
    "@loopdog/config": "0.4.0",
    "@loopdog/github": "0.4.0",
    "@loopdog/runtime": "0.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmeyer90/loopdog.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "bundle": "tsup && cp -R ../../templates dist/templates",
    "prepack": "npm run bundle",
    "postpack": "rm -rf dist && tsc -b"
  }
}
